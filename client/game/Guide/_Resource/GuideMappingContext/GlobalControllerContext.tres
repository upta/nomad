[gd_resource type="Resource" script_class="GUIDEMappingContext" format=3 ]

[ext_resource type="Script" path="res://addons/guide/guide_action_mapping.gd" id="1_mapping"]
[ext_resource type="Resource" path="res://game/Guide/_Resource/GuideAction/SwitchToKbm.tres" id="2_action"]
[ext_resource type="Script" path="res://addons/guide/guide_mapping_context.gd" id="3_ctx"]
[ext_resource type="Script" path="res://addons/guide/guide_input_mapping.gd" id="4_input"]
[ext_resource type="Script" path="res://addons/guide/inputs/guide_input_any.gd" id="5_any"]
[ext_resource type="Script" path="res://addons/guide/modifiers/guide_modifier.gd" id="6_mod"]
[ext_resource type="Script" path="res://addons/guide/triggers/guide_trigger.gd" id="7_trigger"]
[ext_resource type="Script" path="res://addons/guide/triggers/guide_trigger_pressed.gd" id="8_pressed"]

[sub_resource type="Resource" id="Resource_any_input"]
script = ExtResource("5_any")
mouse_buttons = true
mouse_movement = true
keyboard = true
mouse = true
joy = false

[sub_resource type="Resource" id="Resource_pressed"]
script = ExtResource("8_pressed")

[sub_resource type="Resource" id="Resource_input"]
script = ExtResource("4_input")
input = SubResource("Resource_any_input")
