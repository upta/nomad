[sub_resource type="Resource" id="Resource_action"]
script = ExtResource("1_mapping")
action = ExtResource("2_action")
input_mappings = Array[ExtResource("4_input")]([SubResource("Resource_input")])

[resource]
script = ExtResource("3_ctx")
mappings = Array[ExtResource("1_mapping")]([SubResource("Resource_action")])
