[ext_resource type="Script" path="res://addons/guide/inputs/guide_input_joy_axis_1d.gd" id="11_af52p"]
[ext_resource type="Script" path="res://addons/guide/inputs/guide_input_joy_button.gd" id="11_joybtn"]

[sub_resource type="Resource" id="Resource_joy_axis"]
script = ExtResource("5_joy2d")

[sub_resource type="Resource" id="Resource_deadzone"]
script = ExtResource("7_deadzone")

[sub_resource type="Resource" id="Resource_joy_input"]
script = ExtResource("4_input")
input = SubResource("Resource_joy_axis")
modifiers = Array[ExtResource("6_mod")]([SubResource("Resource_deadzone")])

[sub_resource type="Resource" id="Resource_move_action"]
script = ExtResource("1_mapping")
action = ExtResource("3_move")
input_mappings = Array[ExtResource("4_input")]([SubResource("Resource_joy_input")])

[sub_resource type="Resource" id="Resource_interact_btn"]
script = ExtResource("11_joybtn")

[sub_resource type="Resource" id="Resource_4iura"]
script = ExtResource("10_y3k2f")

[sub_resource type="Resource" id="Resource_interact_input"]
script = ExtResource("4_input")
input = SubResource("Resource_interact_btn")
triggers = Array[ExtResource("7_lnrlo")]([SubResource("Resource_4iura")])

[sub_resource type="Resource" id="Resource_interact_action"]
script = ExtResource("1_mapping")
action = ExtResource("8_interact")
input_mappings = Array[ExtResource("4_input")]([SubResource("Resource_interact_input")])

[sub_resource type="Resource" id="Resource_y3k2f"]
script = ExtResource("11_af52p")
axis = 5

[sub_resource type="Resource" id="Resource_cycle_input"]
script = ExtResource("4_input")
input = SubResource("Resource_y3k2f")

[sub_resource type="Resource" id="Resource_cycle_action"]
script = ExtResource("1_mapping")
action = ExtResource("10_h04xt")
input_mappings = Array[ExtResource("4_input")]([SubResource("Resource_cycle_input")])
metadata/_guide_input_mappings_collapsed = false

[sub_resource type="Resource" id="Resource_xbfr2"]
script = ExtResource("11_joybtn")
button = 2

[sub_resource type="Resource" id="Resource_drop_input"]
script = ExtResource("4_input")
input = SubResource("Resource_xbfr2")

[sub_resource type="Resource" id="Resource_drop_action"]
script = ExtResource("1_mapping")
action = ExtResource("10_drop")
input_mappings = Array[ExtResource("4_input")]([SubResource("Resource_drop_input")])

[resource]
script = ExtResource("2_ctx")
mappings = Array[ExtResource("1_mapping")]([SubResource("Resource_move_action"), SubResource("Resource_interact_action"), SubResource("Resource_cycle_action"), SubResource("Resource_drop_action")])
