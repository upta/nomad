[ext_resource type="Resource" path="res://game/Player/_Input/Actions/CharacterMove.tres" id="3_move"]
[ext_resource type="Script" path="res://addons/guide/guide_input_mapping.gd" id="4_input"]
[ext_resource type="Script" path="res://addons/guide/inputs/guide_input_joy_axis_2d.gd" id="5_joy2d"]
[ext_resource type="Script" path="res://addons/guide/modifiers/guide_modifier.gd" id="6_mod"]
[ext_resource type="Script" path="res://addons/guide/modifiers/guide_modifier_deadzone.gd" id="7_deadzone"]
[ext_resource type="Script" path="res://addons/guide/triggers/guide_trigger.gd" id="7_lnrlo"]
[ext_resource type="Resource" path="res://game/Player/_Input/Actions/Interact.tres" id="8_interact"]
[ext_resource type="Resource" path="res://game/Player/_Input/Actions/HotbarDropItem.tres" id="10_drop"]
[ext_resource type="Resource" path="res://game/Player/_Input/Actions/HotbarCycleSlot.tres" id="10_h04xt"]
