{
  "scenario_id": "pressure_corridor_depressurizes",
  "version": 3,
  "description": "The corridor (slot 7, one pressure unit for the whole network) depressurizes like a room: its tint shifts toward VacuumTint — blue rises, and rises more than red (hue-shift assert; the corridor base color is near the tint hue, so red also rises slightly). Repressurizing restores the baseline.",
  "harness_scene": "res://validation/harnesses/PowerHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/PowerHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "baseline" },
    { "op": "assert_value", "checkpoint": "baseline", "path": "harness_state.grid.rooms.7.slot_index", "comparator": "eq", "expected": 7 },
    { "op": "assert_value", "checkpoint": "baseline", "path": "harness_state.grid.rooms.7.is_pressurized", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "test_depressurize_corridor" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_depressurize_corridor" },
    { "op": "wait_until", "path": "harness_state.grid.rooms.7.is_pressurized", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "corridor_vacuum" },
    { "op": "assert_value", "checkpoint": "corridor_vacuum", "path": "harness_state.grid.rooms.5.is_pressurized", "comparator": "eq", "expected": true },
    {
      "op": "assert_pipeline",
      "sources": {
        "baseline_b": { "kind": "checkpoint", "checkpoint": "baseline", "path": "harness_state.grid.rooms.7.color_b" },
        "vacuum_b": { "kind": "checkpoint", "checkpoint": "corridor_vacuum", "path": "harness_state.grid.rooms.7.color_b" }
      },
      "pipeline": [
        { "op": "subtract", "inputs": ["vacuum_b", "baseline_b"], "as": "b_delta" }
      ],
      "assert": { "actual": "b_delta", "comparator": "gt", "expected": 0 }
    },
    {
      "op": "assert_pipeline",
      "sources": {
        "baseline_r": { "kind": "checkpoint", "checkpoint": "baseline", "path": "harness_state.grid.rooms.7.color_r" },
        "vacuum_r": { "kind": "checkpoint", "checkpoint": "corridor_vacuum", "path": "harness_state.grid.rooms.7.color_r" },
        "baseline_b": { "kind": "checkpoint", "checkpoint": "baseline", "path": "harness_state.grid.rooms.7.color_b" },
        "vacuum_b": { "kind": "checkpoint", "checkpoint": "corridor_vacuum", "path": "harness_state.grid.rooms.7.color_b" }
      },
      "pipeline": [
        { "op": "subtract", "inputs": ["vacuum_b", "baseline_b"], "as": "b_delta" },
        { "op": "subtract", "inputs": ["vacuum_r", "baseline_r"], "as": "r_delta" },
        { "op": "subtract", "inputs": ["b_delta", "r_delta"], "as": "hue_shift" }
      ],
      "assert": { "actual": "hue_shift", "comparator": "gt", "expected": 0 }
    },
    { "op": "press_action", "action": "test_repressurize_corridor" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_repressurize_corridor" },
    { "op": "wait_until", "path": "harness_state.grid.rooms.7.is_pressurized", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "restored" },
    {
      "op": "assert_pipeline",
      "sources": {
        "baseline_b": { "kind": "checkpoint", "checkpoint": "baseline", "path": "harness_state.grid.rooms.7.color_b" },
        "restored_b": { "kind": "checkpoint", "checkpoint": "restored", "path": "harness_state.grid.rooms.7.color_b" }
      },
      "pipeline": [
        { "op": "subtract", "inputs": ["restored_b", "baseline_b"], "as": "b_diff" },
        { "op": "abs", "inputs": ["b_diff"], "as": "abs_b_diff" }
      ],
      "assert": { "actual": "abs_b_diff", "comparator": "lte", "expected": 0.001 }
    },
    { "op": "quit" }
  ]
}
