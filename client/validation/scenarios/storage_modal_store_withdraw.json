{
  "scenario_id": "storage_modal_store_withdraw",
  "version": 3,
  "description": "The Cargo Bay terminal opens the StorageModal dual grid: two seeded hotbar items show in the hotbar grid, accepting the focused slot deposits it into cargo (stored count 1, hotbar slot empties, title updates), focusing down into the cargo grid and accepting withdraws it back, and Esc closes the modal.",
  "harness_scene": "res://validation/harnesses/InventoryHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/InventoryHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "test_seed_biomass_slot0" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "test_seed_biomass_slot0" },
    { "op": "press_action", "action": "test_seed_ore_slot2" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "test_seed_ore_slot2" },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.player.x", "comparator": "gte", "expected": 300, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "move_down" },
    { "op": "wait_until", "path": "harness_state.interaction.focused_label", "comparator": "contains", "expected": "Cargo Bay Terminal", "timeout_frames": 600 },
    { "op": "release_action", "action": "move_down" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "modal_open" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.title", "comparator": "eq", "expected": "Cargo Bay" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.storage_title", "comparator": "eq", "expected": "Cargo Storage (0/12)" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.hotbar_occupied", "comparator": "eq", "expected": 2 },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.cargo_occupied", "comparator": "eq", "expected": 0 },
    { "op": "press_action", "action": "modal_accept" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_accept" },
    { "op": "wait_until", "path": "harness_state.modal.stored_shown", "comparator": "eq", "expected": 1, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "deposited" },
    { "op": "assert_value", "checkpoint": "deposited", "path": "harness_state.storage.stored_in_cargo", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "deposited", "path": "harness_state.modal.hotbar_occupied", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "deposited", "path": "harness_state.modal.cargo_occupied", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "deposited", "path": "harness_state.modal.storage_title", "comparator": "eq", "expected": "Cargo Storage (1/12)" },
    { "op": "assert_value", "checkpoint": "deposited", "path": "harness_state.modal.open", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "press_action", "action": "modal_accept" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_accept" },
    { "op": "wait_until", "path": "harness_state.modal.stored_shown", "comparator": "eq", "expected": 0, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "withdrawn" },
    { "op": "assert_value", "checkpoint": "withdrawn", "path": "harness_state.storage.stored_in_cargo", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "withdrawn", "path": "harness_state.modal.hotbar_occupied", "comparator": "eq", "expected": 2 },
    { "op": "assert_value", "checkpoint": "withdrawn", "path": "harness_state.modal.open", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "ui_cancel_modal" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "ui_cancel_modal" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "quit" }
  ]
}
