{
  "scenario_id": "ghost_cannot_interact",
  "version": 3,
  "description": "Ghost interaction filtering: a ghost floating over the Kitchen terminal gets no focus, no prompt, and no modal on interact; the Cloning Bay terminal is the single exception — it focuses and opens for ghosts (their anchor back to life).",
  "harness_scene": "res://validation/harnesses/GhostHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/GhostHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "test_kill" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_kill" },
    { "op": "wait_until", "path": "harness_state.player.is_ghost", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "press_action", "action": "move_down" },
    { "op": "wait_until", "path": "harness_state.player.y", "comparator": "gt", "expected": 130, "timeout_frames": 300 },
    { "op": "release_action", "action": "move_down" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "at_kitchen_terminal" },
    { "op": "assert_value", "checkpoint": "at_kitchen_terminal", "path": "harness_state.interaction.focused_label", "comparator": "eq", "expected": "" },
    { "op": "assert_value", "checkpoint": "at_kitchen_terminal", "path": "harness_state.interaction.prompt_visible", "comparator": "eq", "expected": false },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "no_modal_for_ghost" },
    { "op": "assert_value", "checkpoint": "no_modal_for_ghost", "path": "harness_state.modal.open", "comparator": "eq", "expected": false },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.player.x", "comparator": "gt", "expected": 110, "timeout_frames": 300 },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "move_up" },
    { "op": "wait_until", "path": "harness_state.interaction.focused_label", "comparator": "contains", "expected": "Cloning Bay", "timeout_frames": 600 },
    { "op": "release_action", "action": "move_up" },
    { "op": "checkpoint", "name": "at_cloning_terminal" },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "checkpoint", "name": "cloning_modal_open_for_ghost" },
    { "op": "assert_value", "checkpoint": "cloning_modal_open_for_ghost", "path": "harness_state.modal.title", "comparator": "contains", "expected": "Cloning" },
    { "op": "quit" }
  ]
}
