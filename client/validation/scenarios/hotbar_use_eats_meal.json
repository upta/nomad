{
  "scenario_id": "hotbar_use_eats_meal",
  "version": 3,
  "description": "Pressing the use key (F) on a selected Meal consumes it from the hotbar and restores the hunger HUD by the meal amount; pressing use on a non-edible item (RawOre) is a no-op — item stays, hunger unchanged.",
  "harness_scene": "res://validation/harnesses/InventoryHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/InventoryHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "start" },
    { "op": "assert_value", "checkpoint": "start", "path": "harness_state.hotbar.slots.0.occupied", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "start", "path": "harness_state.vitals.hunger_fill_ratio", "comparator": "eq", "expected": 1 },
    { "op": "press_action", "action": "test_set_hunger_low" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_hunger_low" },
    { "op": "press_action", "action": "test_give_meal_slot0" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_give_meal_slot0" },
    { "op": "wait_until", "path": "harness_state.hotbar.slots.0.glyph", "comparator": "eq", "expected": "M", "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "meal_ready" },
    { "op": "assert_value", "checkpoint": "meal_ready", "path": "harness_state.hotbar.slots.0.occupied", "comparator": "eq", "expected": true },
    { "op": "assert_value", "checkpoint": "meal_ready", "path": "harness_state.vitals.hunger", "comparator": "eq", "expected": 10 },
    { "op": "press_action", "action": "hotbar_use" },
    { "op": "wait_frames", "frames": 12 },
    { "op": "release_action", "action": "hotbar_use" },
    { "op": "wait_until", "path": "harness_state.vitals.hunger", "comparator": "gte", "expected": 60, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "eaten" },
    { "op": "assert_value", "checkpoint": "eaten", "path": "harness_state.hotbar.slots.0.occupied", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "eaten", "path": "harness_state.vitals.hunger", "comparator": "eq", "expected": 60 },
    { "op": "assert_value", "checkpoint": "eaten", "path": "harness_state.vitals.hunger_fill_ratio", "comparator": "gt", "expected": 0.5 },
    { "op": "press_action", "action": "test_give_ore_slot0" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_give_ore_slot0" },
    { "op": "wait_until", "path": "harness_state.hotbar.slots.0.glyph", "comparator": "eq", "expected": "O", "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "ore_ready" },
    { "op": "press_action", "action": "hotbar_use" },
    { "op": "wait_frames", "frames": 15 },
    { "op": "release_action", "action": "hotbar_use" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "no_op" },
    { "op": "assert_value", "checkpoint": "no_op", "path": "harness_state.hotbar.slots.0.occupied", "comparator": "eq", "expected": true },
    { "op": "assert_value", "checkpoint": "no_op", "path": "harness_state.hotbar.slots.0.glyph", "comparator": "eq", "expected": "O" },
    { "op": "assert_value", "checkpoint": "no_op", "path": "harness_state.vitals.hunger", "comparator": "eq", "expected": 60 },
    { "op": "quit" }
  ]
}
