{
  "scenario_id": "ghost_cannot_pickup",
  "version": 3,
  "description": "Ghost pickup filtering: a dead player floating directly over a world ore gets no focus and no prompt (world items are not ghost-accessible), and the same spot focuses the item again immediately after revival.",
  "harness_scene": "res://validation/harnesses/InventoryHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/InventoryHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "test_seed_ore_at_origin" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_seed_ore_at_origin" },
    { "op": "wait_until", "path": "harness_state.world_item_nodes", "comparator": "eq", "expected": 1, "timeout_frames": 120 },
    { "op": "press_action", "action": "test_kill" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_kill" },
    { "op": "wait_until", "path": "harness_state.player.is_ghost", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "press_action", "action": "move_left" },
    { "op": "wait_until", "path": "harness_state.player.x", "comparator": "lt", "expected": 8, "timeout_frames": 300 },
    { "op": "release_action", "action": "move_left" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "ghost_over_item" },
    { "op": "assert_value", "checkpoint": "ghost_over_item", "path": "harness_state.interaction.focused_label", "comparator": "eq", "expected": "" },
    { "op": "assert_value", "checkpoint": "ghost_over_item", "path": "harness_state.interaction.prompt_visible", "comparator": "eq", "expected": false },
    { "op": "press_action", "action": "test_revive" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_revive" },
    { "op": "wait_until", "path": "harness_state.player.is_ghost", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "wait_until", "path": "harness_state.interaction.focused_label", "comparator": "eq", "expected": "Pick up Raw Ore", "timeout_frames": 120 },
    { "op": "checkpoint", "name": "alive_focuses" },
    { "op": "assert_value", "checkpoint": "alive_focuses", "path": "harness_state.interaction.prompt_visible", "comparator": "eq", "expected": true },
    { "op": "quit" }
  ]
}
