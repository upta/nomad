{
  "scenario_id": "power_router_modal_toggles_breaker",
  "version": 3,
  "description": "Interacting with a PowerRouter terminal opens the grid-overview modal; keyboard navigation (down x5 + accept) toggles the slot-5 row's breaker off (room loses power), accept again restores it, and Esc closes the modal.",
  "harness_scene": "res://validation/harnesses/PowerHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/PowerHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "test_assign_kitchen_reactor" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_assign_kitchen_reactor" },
    { "op": "wait_until", "path": "harness_state.grid.rooms.5.label", "comparator": "eq", "expected": "Reactor", "timeout_frames": 120 },
    { "op": "press_action", "action": "move_down" },
    { "op": "wait_until", "path": "harness_state.interaction.focused_label", "comparator": "contains", "expected": "Reactor Terminal", "timeout_frames": 300 },
    { "op": "release_action", "action": "move_down" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "modal_open" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.title", "comparator": "eq", "expected": "Reactor" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.grid.rooms.5.breaker_on", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 3 },
    { "op": "press_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 3 },
    { "op": "press_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 3 },
    { "op": "press_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 3 },
    { "op": "press_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 3 },
    { "op": "press_action", "action": "modal_accept" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_accept" },
    { "op": "wait_until", "path": "harness_state.grid.rooms.5.breaker_on", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "row_toggled_off" },
    { "op": "assert_value", "checkpoint": "row_toggled_off", "path": "harness_state.grid.rooms.5.is_powered", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "row_toggled_off", "path": "harness_state.modal.open", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "modal_accept" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_accept" },
    { "op": "wait_until", "path": "harness_state.grid.rooms.5.breaker_on", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "row_toggled_back" },
    { "op": "assert_value", "checkpoint": "row_toggled_back", "path": "harness_state.grid.rooms.5.is_powered", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "ui_cancel_modal" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "ui_cancel_modal" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "checkpoint", "name": "modal_closed" },
    { "op": "quit" }
  ]
}
