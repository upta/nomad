{
  "scenario_id": "cloning_modal_lists_dead",
  "version": 3,
  "description": "The Cloning Bay terminal opens the CloningModal: it lists deceased crew with the shared biomass pool, and accepting a Clone row consumes biomass and removes the revived crewmate from the list.",
  "harness_scene": "res://validation/harnesses/GhostHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/GhostHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "test_seed_dead_crew" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_seed_dead_crew" },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.player.x", "comparator": "gt", "expected": 100, "timeout_frames": 300 },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "move_up" },
    { "op": "wait_until", "path": "harness_state.interaction.focused_label", "comparator": "contains", "expected": "Cloning Bay Terminal", "timeout_frames": 600 },
    { "op": "release_action", "action": "move_up" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "modal_lists_dead" },
    { "op": "assert_value", "checkpoint": "modal_lists_dead", "path": "harness_state.modal.title", "comparator": "eq", "expected": "Cloning Bay" },
    { "op": "assert_value", "checkpoint": "modal_lists_dead", "path": "harness_state.modal.dead_rows", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "modal_lists_dead", "path": "harness_state.modal.biomass", "comparator": "eq", "expected": 3 },
    { "op": "press_action", "action": "modal_accept" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_accept" },
    { "op": "wait_until", "path": "harness_state.modal.dead_rows", "comparator": "eq", "expected": 0, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "crew_cloned" },
    { "op": "assert_value", "checkpoint": "crew_cloned", "path": "harness_state.modal.biomass", "comparator": "eq", "expected": 2 },
    { "op": "press_action", "action": "ui_cancel_modal" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "ui_cancel_modal" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "quit" }
  ]
}
