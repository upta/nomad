{
  "scenario_id": "pressure_modal_shows_lost",
  "version": 3,
  "description": "Pressurization's player-facing text surface: with Hydroponics depressurized, opening its room terminal modal carries IsPressurized=false so RoomInfoModal renders 'Pressure: Lost' (checkpoint screenshot is the visual proof). Hydroponics is used because it keeps an Info terminal in-game — Kitchen/Workshop are now crafting benches whose modals don't show room status.",
  "harness_scene": "res://validation/harnesses/PowerHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/PowerHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "test_depressurize_hydroponics" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_depressurize_hydroponics" },
    { "op": "wait_until", "path": "harness_state.grid.rooms.3.is_pressurized", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "checkpoint", "name": "depressurized" },
    { "op": "press_action", "action": "test_open_hydroponics_info_modal" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_open_hydroponics_info_modal" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "modal_pressure_lost" },
    { "op": "assert_value", "checkpoint": "modal_pressure_lost", "path": "harness_state.modal.title", "comparator": "eq", "expected": "Hydroponics" },
    { "op": "assert_value", "checkpoint": "modal_pressure_lost", "path": "harness_state.modal.pressure_nominal", "comparator": "eq", "expected": false },
    { "op": "press_action", "action": "ui_cancel_modal" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "ui_cancel_modal" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "quit" }
  ]
}
