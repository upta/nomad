{
  "scenario_id": "pressure_modal_shows_lost",
  "version": 3,
  "description": "Pressurization's player-facing text surface: with the Kitchen depressurized, walking to its terminal and interacting opens the room modal carrying IsPressurized=false (RoomInfoModal renders 'Pressure: Lost' — checkpoint screenshot is the visual proof).",
  "harness_scene": "res://validation/harnesses/PowerHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/PowerHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "test_depressurize_kitchen" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_depressurize_kitchen" },
    { "op": "wait_until", "path": "harness_state.grid.rooms.5.is_pressurized", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "checkpoint", "name": "depressurized" },
    { "op": "press_action", "action": "move_down" },
    { "op": "wait_until", "path": "harness_state.interaction.focused_label", "comparator": "contains", "expected": "Kitchen Terminal", "timeout_frames": 300 },
    { "op": "release_action", "action": "move_down" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "at_terminal" },
    { "op": "assert_value", "checkpoint": "at_terminal", "path": "harness_state.modal.open", "comparator": "eq", "expected": false },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "modal_pressure_lost" },
    { "op": "assert_value", "checkpoint": "modal_pressure_lost", "path": "harness_state.modal.title", "comparator": "eq", "expected": "Kitchen" },
    { "op": "assert_value", "checkpoint": "modal_pressure_lost", "path": "harness_state.modal.pressure_nominal", "comparator": "eq", "expected": false },
    { "op": "press_action", "action": "ui_cancel_modal" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "ui_cancel_modal" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "quit" }
  ]
}
