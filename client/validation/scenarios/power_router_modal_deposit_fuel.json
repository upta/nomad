{
  "scenario_id": "power_router_modal_deposit_fuel",
  "version": 3,
  "description": "The PowerRouterModal's fuel section: the modal shows the ship's fuel count, focusing up from the first breaker row reaches the fuel cell deposit row, accepting deposits the held cell - fuel 5 to 6, row disables in place - and the modal stays open.",
  "harness_scene": "res://validation/harnesses/PowerHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/PowerHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "test_assign_kitchen_reactor" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_assign_kitchen_reactor" },
    { "op": "wait_until", "path": "harness_state.grid.rooms.5.label", "comparator": "eq", "expected": "Reactor", "timeout_frames": 120 },
    { "op": "press_action", "action": "test_seed_fuel_store" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_seed_fuel_store" },
    { "op": "press_action", "action": "test_seed_fuel_cell" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_seed_fuel_cell" },
    { "op": "press_action", "action": "move_down" },
    { "op": "wait_until", "path": "harness_state.interaction.focused_label", "comparator": "contains", "expected": "Reactor Terminal", "timeout_frames": 300 },
    { "op": "release_action", "action": "move_down" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "modal_open" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.title", "comparator": "eq", "expected": "Reactor" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.fuel", "comparator": "eq", "expected": 5 },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.fuel_deposit_enabled", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "modal_up" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "modal_up" },
    { "op": "wait_frames", "frames": 3 },
    { "op": "press_action", "action": "modal_accept" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "modal_accept" },
    { "op": "wait_until", "path": "harness_state.modal.fuel", "comparator": "eq", "expected": 6, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "deposited" },
    { "op": "assert_value", "checkpoint": "deposited", "path": "harness_state.modal.fuel_deposit_enabled", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "deposited", "path": "harness_state.modal.open", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "ui_cancel_modal" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "ui_cancel_modal" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "quit" }
  ]
}
