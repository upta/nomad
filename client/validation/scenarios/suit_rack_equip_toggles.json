{
  "scenario_id": "suit_rack_equip_toggles",
  "version": 3,
  "description": "The Cargo Bay suit rack equips and unequips a spacesuit: one rack spawns in the CargoBay-assigned slot; walking up and interacting equips the suit (player tint changes, movement speed modifier drops to the suit factor); interacting again unequips and restores full speed.",
  "harness_scene": "res://validation/harnesses/PowerHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/PowerHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "initial" },
    { "op": "assert_value", "checkpoint": "initial", "path": "harness_state.grid.map.suit_rack_count", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "initial", "path": "harness_state.vitals.suit_equipped", "comparator": "eq", "expected": false },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.player.x", "comparator": "gt", "expected": 296, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "move_down" },
    { "op": "wait_until", "path": "harness_state.player.y", "comparator": "gt", "expected": 80, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_down" },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.player.x", "comparator": "gt", "expected": 420, "timeout_frames": 600 },
    { "op": "press_action", "action": "move_up" },
    { "op": "wait_until", "path": "harness_state.interaction.focused_label", "comparator": "contains", "expected": "Suit Rack", "timeout_frames": 600 },
    { "op": "release_action", "action": "move_up" },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "at_rack" },
    { "op": "assert_value", "checkpoint": "at_rack", "path": "harness_state.player.speed_modifier", "comparator": "gt", "expected": 0.95 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.vitals.suit_equipped", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "suited" },
    { "op": "assert_value", "checkpoint": "suited", "path": "harness_state.player.speed_modifier", "comparator": "lt", "expected": 0.85 },
    { "op": "assert_value", "checkpoint": "suited", "path": "harness_state.player.speed_modifier", "comparator": "gt", "expected": 0.75 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.vitals.suit_equipped", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "unequipped" },
    { "op": "assert_value", "checkpoint": "unequipped", "path": "harness_state.player.speed_modifier", "comparator": "gt", "expected": 0.95 },
    { "op": "quit" }
  ]
}
