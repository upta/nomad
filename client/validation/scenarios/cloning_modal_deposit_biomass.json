{
  "scenario_id": "cloning_modal_deposit_biomass",
  "version": 3,
  "description": "The CloningModal's biomass deposit row: with a biomass item held the row is enabled and focused (no dead crew), accepting deposits it - shared biomass 3 to 4, hotbar emptied, row disables in place - and the modal stays open.",
  "harness_scene": "res://validation/harnesses/GhostHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/GhostHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "test_seed_biomass_item" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_seed_biomass_item" },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.player.x", "comparator": "gt", "expected": 100, "timeout_frames": 300 },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "move_up" },
    { "op": "wait_until", "path": "harness_state.interaction.focused_label", "comparator": "contains", "expected": "Cloning Bay Terminal", "timeout_frames": 600 },
    { "op": "release_action", "action": "move_up" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "modal_open" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.title", "comparator": "eq", "expected": "Cloning Bay" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.biomass", "comparator": "eq", "expected": 3 },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.deposit_enabled", "comparator": "eq", "expected": true },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.items.biomass_held", "comparator": "eq", "expected": 1 },
    { "op": "press_action", "action": "modal_accept" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_accept" },
    { "op": "wait_until", "path": "harness_state.modal.biomass", "comparator": "eq", "expected": 4, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "deposited" },
    { "op": "assert_value", "checkpoint": "deposited", "path": "harness_state.items.biomass_held", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "deposited", "path": "harness_state.modal.deposit_enabled", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "deposited", "path": "harness_state.modal.open", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "ui_cancel_modal" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "ui_cancel_modal" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "quit" }
  ]
}
