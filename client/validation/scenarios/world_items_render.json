{
  "scenario_id": "world_items_render",
  "version": 3,
  "description": "Seeded world items render as one WorldItem node each at their seeded positions with per-type color and glyph (RawOre at origin, FuelCell in the Kitchen); removing an item frees its node.",
  "harness_scene": "res://validation/harnesses/InventoryHarness.tscn",
  "done_contract": { "ore_color_r": 0.62, "fuelcell_color_r": 0.95, "color_tolerance": 0.01 },
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/InventoryHarness.tscn" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "empty" },
    { "op": "assert_value", "checkpoint": "empty", "path": "harness_state.world_item_nodes", "comparator": "eq", "expected": 0 },
    { "op": "press_action", "action": "test_seed_ore_at_origin" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_seed_ore_at_origin" },
    { "op": "press_action", "action": "test_seed_fuelcell_in_kitchen" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_seed_fuelcell_in_kitchen" },
    { "op": "wait_until", "path": "harness_state.world_item_nodes", "comparator": "eq", "expected": 2, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "seeded" },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.world_items.0.glyph", "comparator": "eq", "expected": "O" },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.world_items.0.x", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.world_items.0.y", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.world_items.1.glyph", "comparator": "eq", "expected": "E" },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.world_items.1.x", "comparator": "eq", "expected": 16 },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.world_items.1.y", "comparator": "eq", "expected": 144 },
    {
      "op": "assert_pipeline",
      "sources": {
        "observed_r": { "kind": "checkpoint", "checkpoint": "seeded", "path": "harness_state.world_items.0.color_r" },
        "expected_r": { "kind": "contract", "path": "done_contract.ore_color_r" },
        "tolerance": { "kind": "contract", "path": "done_contract.color_tolerance" }
      },
      "pipeline": [
        { "op": "subtract", "inputs": ["observed_r", "expected_r"], "as": "diff" },
        { "op": "abs", "inputs": ["diff"], "as": "abs_diff" }
      ],
      "assert": { "actual": "abs_diff", "comparator": "lte", "expected_source": "tolerance" }
    },
    {
      "op": "assert_pipeline",
      "sources": {
        "observed_r": { "kind": "checkpoint", "checkpoint": "seeded", "path": "harness_state.world_items.1.color_r" },
        "expected_r": { "kind": "contract", "path": "done_contract.fuelcell_color_r" },
        "tolerance": { "kind": "contract", "path": "done_contract.color_tolerance" }
      },
      "pipeline": [
        { "op": "subtract", "inputs": ["observed_r", "expected_r"], "as": "diff" },
        { "op": "abs", "inputs": ["diff"], "as": "abs_diff" }
      ],
      "assert": { "actual": "abs_diff", "comparator": "lte", "expected_source": "tolerance" }
    },
    { "op": "press_action", "action": "test_remove_ore" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_remove_ore" },
    { "op": "wait_until", "path": "harness_state.world_item_nodes", "comparator": "eq", "expected": 1, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "ore_removed" },
    { "op": "assert_value", "checkpoint": "ore_removed", "path": "harness_state.world_items.0.glyph", "comparator": "eq", "expected": "E" },
    { "op": "quit" }
  ]
}
