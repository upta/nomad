{
  "scenario_id": "hotbar_inert_while_modal_open",
  "version": 3,
  "description": "Hotbar direct-select keys live in the character GUIDE context, so an open terminal modal (exclusive UiModeContext) mutes them: pressing key 3 with the modal open leaves the selection unchanged, and the same press works again after Esc closes the modal.",
  "harness_scene": "res://validation/harnesses/InventoryHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/InventoryHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "initial" },
    { "op": "assert_value", "checkpoint": "initial", "path": "harness_state.hotbar.selected", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "initial", "path": "harness_state.modal.open", "comparator": "eq", "expected": false },
    { "op": "press_action", "action": "test_open_kitchen_modal" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_open_kitchen_modal" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "hotbar_slot_3" },
    { "op": "wait_frames", "frames": 12 },
    { "op": "release_action", "action": "hotbar_slot_3" },
    { "op": "wait_frames", "frames": 20 },
    { "op": "checkpoint", "name": "pressed_while_open" },
    { "op": "assert_value", "checkpoint": "pressed_while_open", "path": "harness_state.hotbar.selected", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "pressed_while_open", "path": "harness_state.modal.open", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "ui_cancel_modal" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "ui_cancel_modal" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "hotbar_slot_3" },
    { "op": "wait_frames", "frames": 12 },
    { "op": "release_action", "action": "hotbar_slot_3" },
    { "op": "wait_until", "path": "harness_state.hotbar.selected", "comparator": "eq", "expected": 2, "timeout_frames": 120 },
    { "op": "checkpoint", "name": "selected_after_close" },
    { "op": "quit" }
  ]
}
