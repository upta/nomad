{
  "scenario_id": "storage_modal_shows_existing_stored_items",
  "version": 3,
  "description": "Opening the Cargo Bay StorageModal on an item that was already in storage (seeded before the modal opens, as after a reload) shows it immediately: title 1/12 and one occupied cargo slot, with no store action performed in this session.",
  "harness_scene": "res://validation/harnesses/InventoryHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/InventoryHarness.tscn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "test_seed_stored_ore_cargo" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "test_seed_stored_ore_cargo" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.player.x", "comparator": "gte", "expected": 300, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "move_down" },
    { "op": "wait_until", "path": "harness_state.interaction.focused_label", "comparator": "contains", "expected": "Cargo Bay Terminal", "timeout_frames": 600 },
    { "op": "release_action", "action": "move_down" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "modal_open" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.title", "comparator": "eq", "expected": "Cargo Bay" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.storage_title", "comparator": "eq", "expected": "Cargo Storage (1/12)" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.stored_shown", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.modal.cargo_occupied", "comparator": "eq", "expected": 1 },
    { "op": "press_action", "action": "ui_cancel_modal" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "ui_cancel_modal" },
    { "op": "wait_until", "path": "harness_state.modal.open", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "quit" }
  ]
}
