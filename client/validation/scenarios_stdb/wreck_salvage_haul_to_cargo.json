{
  "scenario_id": "wreck_salvage_haul_to_cargo",
  "version": 3,
  "description": "The wreck salvage loop, end to end across two clients. At the Wreck node the crew crosses the airlock onto the derelict, picks a Components salvage item up off the surface into the hotbar, crosses back into the ship, and stores it in the Cargo Bay. The store is server-authoritative (LoadItem reach-checked against the Cargo Bay slot center), so it survives the airlock crossing, and the puppet client sees the item become Stored. Teleports stand in for navigation (the proven spawn-at-player + MoveEntity pattern).",
  "harness_scene": "res://validation/harnesses/MultiplayerGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/MultiplayerGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.puppet.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 7, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_set_node_wreck" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_node_wreck" },
    { "op": "wait_until", "path": "harness_state.node.kind", "comparator": "eq", "expected": "Wreck", "timeout_frames": 300 },
    { "op": "press_action", "action": "test_clear_creatures" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_creatures" },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_teleport_to_airlock" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_teleport_to_airlock" },
    { "op": "press_action", "action": "test_enter_exterior" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_enter_exterior" },
    { "op": "wait_until", "path": "harness_state.zone.in_exterior", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "on_wreck" },
    { "op": "assert_value", "checkpoint": "on_wreck", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": -1 },

    { "op": "press_action", "action": "test_spawn_components_at_player" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_components_at_player" },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_pickup_nearest_world_item" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_pickup_nearest_world_item" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "loot_in_hand" },
    { "op": "assert_value", "checkpoint": "loot_in_hand", "path": "harness_state.items.hotbar.0", "comparator": "eq", "expected": "Components" },
    { "op": "assert_value", "checkpoint": "loot_in_hand", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0 },

    { "op": "press_action", "action": "test_teleport_to_airlock" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_teleport_to_airlock" },
    { "op": "press_action", "action": "test_enter_interior" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_enter_interior" },
    { "op": "wait_until", "path": "harness_state.zone.in_exterior", "comparator": "eq", "expected": false, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_teleport_to_cargo" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_teleport_to_cargo" },
    { "op": "press_action", "action": "test_store_slot0_to_cargo" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_store_slot0_to_cargo" },
    { "op": "wait_until", "path": "harness_state.items.stored_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.puppet.stored_item_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "stowed_in_cargo" },
    { "op": "assert_value", "checkpoint": "stowed_in_cargo", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "stowed_in_cargo", "path": "harness_state.items.stored.6.0.type", "comparator": "eq", "expected": "Components" },
    { "op": "assert_value", "checkpoint": "stowed_in_cargo", "path": "harness_state.puppet.stored_item_count", "comparator": "eq", "expected": 1 },
    { "op": "quit" }
  ]
}
