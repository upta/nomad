{
  "scenario_id": "reactor_fuel_burn_blackout_recovery",
  "version": 3,
  "description": "The keep-the-reactor-fed loop: with fast burn enabled the fuel tank drains on scheduled ticks, hitting zero silences the reactor and sends the grid through Overload into Blackout, and depositing a fuel cell at the Reactor recovers the grid to Stable with rooms repowered.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_short_grace" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_short_grace" },
    { "op": "wait_until", "path": "harness_state.power.grace_millis", "comparator": "eq", "expected": 500, "timeout_frames": 300 },
    { "op": "press_action", "action": "move_left" },
    { "op": "wait_until", "path": "harness_state.connection.local_entity.x", "comparator": "lte", "expected": -300, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_left" },
    { "op": "press_action", "action": "move_up" },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 0, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_up" },
    { "op": "release_action", "action": "move_right" },
    { "op": "press_action", "action": "test_give_fuelcell_slot0" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_give_fuelcell_slot0" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_set_fuel_two" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_fuel_two" },
    { "op": "wait_until", "path": "harness_state.stores.fuel", "comparator": "eq", "expected": 2, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "fueled" },
    { "op": "press_action", "action": "test_fast_fuel_burn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_fast_fuel_burn" },
    { "op": "wait_until", "path": "harness_state.power.fuel_burn_millis", "comparator": "eq", "expected": 500, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.stores.fuel", "comparator": "eq", "expected": 0, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.power.status", "comparator": "neq", "expected": "Stable", "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.power.status", "comparator": "eq", "expected": "Blackout", "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.power.rooms.1.is_powered", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "blackout" },
    { "op": "assert_value", "checkpoint": "blackout", "path": "harness_state.power.rooms.0.is_powered", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "blackout", "path": "harness_state.items.hotbar.0", "comparator": "eq", "expected": "FuelCell" },
    { "op": "press_action", "action": "test_slow_fuel_burn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_slow_fuel_burn" },
    { "op": "wait_until", "path": "harness_state.power.fuel_burn_millis", "comparator": "eq", "expected": 120000, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_load_slot0_to_reactor" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_load_slot0_to_reactor" },
    { "op": "wait_until", "path": "harness_state.stores.fuel", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.power.status", "comparator": "eq", "expected": "Stable", "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.power.rooms.1.is_powered", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.power.rooms.0.is_powered", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "recovered" },
    { "op": "press_action", "action": "test_disable_fuel_burn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_disable_fuel_burn" },
    { "op": "wait_until", "path": "harness_state.power.fuel_per_burn", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_set_fuel_full" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_fuel_full" },
    { "op": "wait_until", "path": "harness_state.stores.fuel", "comparator": "eq", "expected": 10, "timeout_frames": 300 },
    { "op": "quit" }
  ]
}
