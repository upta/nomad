{
  "scenario_id": "world_items_seeded_on_init",
  "version": 3,
  "description": "A freshly initialized database seeds two pickupable dev items (RawOre and FuelCell) in the corridor west of the spawn point, and the connected client renders a world node for each.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 2, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.world_item_nodes", "comparator": "eq", "expected": 2, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "seeded_items_render" },
    { "op": "assert_value", "checkpoint": "seeded_items_render", "path": "harness_state.items.by_type.RawOre", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "seeded_items_render", "path": "harness_state.items.by_type.FuelCell", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "seeded_items_render", "path": "harness_state.items.world.0.x", "comparator": "eq", "expected": -96 },
    { "op": "assert_value", "checkpoint": "seeded_items_render", "path": "harness_state.items.world.1.x", "comparator": "eq", "expected": -160 },
    { "op": "quit" }
  ]
}
