{
  "scenario_id": "harvest_cancel_and_rejections",
  "version": 3,
  "description": "The harvest channel's negative paths against a real server: CancelHarvest mid-channel deletes the row and yields nothing; StartHarvest on an out-of-reach node is rejected (no row); StartHarvest on a depleted node is rejected. In every case the hotbar stays empty and node yield is untouched.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "gte", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 4, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_clear_nodes" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_nodes" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_until", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.harvest.progress", "comparator": "gt", "expected": 0.2, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_cancel_harvest" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_cancel_harvest" },
    { "op": "wait_until", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 40 },
    { "op": "checkpoint", "name": "cancelled" },
    { "op": "assert_value", "checkpoint": "cancelled", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "cancelled", "path": "harness_state.nodes.list.0.yield_remaining", "comparator": "eq", "expected": 5 },

    { "op": "press_action", "action": "test_clear_nodes" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_nodes" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_spawn_node_far" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_node_far" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "release_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "checkpoint", "name": "out_of_reach" },
    { "op": "assert_value", "checkpoint": "out_of_reach", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "out_of_reach", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "out_of_reach", "path": "harness_state.nodes.list.0.yield_remaining", "comparator": "eq", "expected": 5 },

    { "op": "press_action", "action": "test_clear_nodes" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_nodes" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_deplete_nearest_node" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_deplete_nearest_node" },
    { "op": "wait_until", "path": "harness_state.nodes.list.0.yield_remaining", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "release_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "checkpoint", "name": "depleted" },
    { "op": "assert_value", "checkpoint": "depleted", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "depleted", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0 },

    { "op": "quit" }
  ]
}
