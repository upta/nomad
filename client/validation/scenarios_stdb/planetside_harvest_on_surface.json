{
  "scenario_id": "planetside_harvest_on_surface",
  "version": 3,
  "description": "Harvesting works unchanged on the exterior surface — the position-agnostic ResourceNode + channel verbs the 4.1 decision promised relocate cleanly. Player crosses the airlock onto Planetside, a node is spawned on their cell, and a fast channel yields one RawOre into the hotbar while the surface node's yield decrements. Seeded creatures cleared so they don't interrupt the channel.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 4, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_set_node_planetside" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_node_planetside" },
    { "op": "wait_until", "path": "harness_state.node.kind", "comparator": "eq", "expected": "Planetside", "timeout_frames": 300 },
    { "op": "press_action", "action": "test_clear_creatures" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_creatures" },
    { "op": "press_action", "action": "test_clear_nodes" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_nodes" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_teleport_to_airlock" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_teleport_to_airlock" },
    { "op": "press_action", "action": "test_enter_exterior" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_enter_exterior" },
    { "op": "wait_until", "path": "harness_state.zone.in_exterior", "comparator": "eq", "expected": true, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "before" },
    { "op": "assert_value", "checkpoint": "before", "path": "harness_state.nodes.list.0.x", "comparator": "gt", "expected": 400 },
    { "op": "assert_value", "checkpoint": "before", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0 },

    { "op": "press_action", "action": "test_fast_harvest" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_fast_harvest" },
    { "op": "press_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_until", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": true, "timeout_frames": 300 },

    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 1, "timeout_frames": 600 },
    { "op": "checkpoint", "name": "harvested" },
    { "op": "assert_value", "checkpoint": "harvested", "path": "harness_state.items.hotbar.0", "comparator": "eq", "expected": "RawOre" },
    { "op": "assert_value", "checkpoint": "harvested", "path": "harness_state.nodes.list.0.yield_remaining", "comparator": "eq", "expected": 4 },
    { "op": "quit" }
  ]
}
