{
  "scenario_id": "resource_nodes_spawn_and_render",
  "version": 3,
  "description": "Switching to Planetside seeds 4 surface ResourceNode rows the client sees (OreVein, OreVein, FuelDepositNode, BiomassPatch out on the exterior grid), the connected Main renders one ResourceNode per row, SpawnResourceNode adds another, and ClearResourceNodes empties everything. (Quiet has no harvestable nodes inside the hull.)",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "gte", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_set_node_planetside" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_node_planetside" },
    { "op": "wait_until", "path": "harness_state.node.kind", "comparator": "eq", "expected": "Planetside", "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 4, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "seeded" },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.nodes.list.0.type", "comparator": "eq", "expected": "OreVein" },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.nodes.list.0.yield_remaining", "comparator": "eq", "expected": 5 },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.nodes.list.0.yield_max", "comparator": "eq", "expected": 5 },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.nodes.list.0.x", "comparator": "eq", "expected": 720 },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.nodes.list.2.type", "comparator": "eq", "expected": "FuelDepositNode" },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.nodes.list.2.x", "comparator": "eq", "expected": 1040 },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.nodes.list.3.type", "comparator": "eq", "expected": "BiomassPatch" },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.nodes.list.3.x", "comparator": "eq", "expected": 1180 },
    { "op": "wait_until", "path": "harness_state.game.resource_node_nodes", "comparator": "eq", "expected": 4, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "rendered" },
    { "op": "press_action", "action": "test_spawn_ore_node" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_ore_node" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 5, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.resource_node_nodes", "comparator": "eq", "expected": 5, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "spawned" },
    { "op": "press_action", "action": "test_clear_nodes" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_nodes" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.resource_node_nodes", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "cleared" },
    { "op": "quit" }
  ]
}
