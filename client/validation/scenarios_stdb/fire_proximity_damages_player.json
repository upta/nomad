{
  "scenario_id": "fire_proximity_damages_player",
  "version": 3,
  "description": "Fire damage round-trips through the server. A single-hazard config (MaxHazards 1, no spread) plus IgniteHazardAt on the player's own cell makes the HazardTick burn the player via the Fire DamageType — health falls. Extinguishing the one fire stops the damage: the hazard count returns to zero and health holds steady.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_until", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 100, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_fast_hazards" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_fast_hazards" },
    { "op": "press_action", "action": "test_ignite_at_player" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_ignite_at_player" },
    { "op": "wait_until", "path": "harness_state.hazards.count", "comparator": "gte", "expected": 1, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "ignited" },
    { "op": "assert_value", "checkpoint": "ignited", "path": "harness_state.hazards.count", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "ignited", "path": "harness_state.hazards.list.0.type", "comparator": "eq", "expected": "Fire" },
    { "op": "wait_until", "path": "harness_state.vitals.health", "comparator": "lt", "expected": 80, "timeout_frames": 600 },
    { "op": "checkpoint", "name": "burning" },
    { "op": "assert_value", "checkpoint": "burning", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": false },
    {
      "op": "assert_pipeline",
      "sources": {
        "h0": { "kind": "checkpoint", "checkpoint": "ignited", "path": "harness_state.vitals.health" },
        "h1": { "kind": "checkpoint", "checkpoint": "burning", "path": "harness_state.vitals.health" }
      },
      "pipeline": [{ "op": "subtract", "inputs": ["h1", "h0"], "as": "delta" }],
      "assert": { "actual": "delta", "comparator": "lt", "expected": 0 }
    },
    { "op": "press_action", "action": "test_extinguish_nearest" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_extinguish_nearest" },
    { "op": "wait_until", "path": "harness_state.hazards.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "extinguished" },
    { "op": "wait_frames", "frames": 90 },
    { "op": "checkpoint", "name": "after_wait" },
    { "op": "assert_value", "checkpoint": "after_wait", "path": "harness_state.hazards.count", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "after_wait", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": false },
    {
      "op": "assert_pipeline",
      "sources": {
        "e0": { "kind": "checkpoint", "checkpoint": "extinguished", "path": "harness_state.vitals.health" },
        "e1": { "kind": "checkpoint", "checkpoint": "after_wait", "path": "harness_state.vitals.health" }
      },
      "pipeline": [
        { "op": "subtract", "inputs": ["e1", "e0"], "as": "hold" },
        { "op": "abs", "inputs": ["hold"], "as": "abs_hold" }
      ],
      "assert": { "actual": "abs_hold", "comparator": "lte", "expected": 0.5 }
    },
    { "op": "quit" }
  ]
}
