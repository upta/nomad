{
  "scenario_id": "player_room_tracking",
  "version": 3,
  "description": "The client tracks which room the local player occupies and reports transitions to the server via SetPlayerRoom: spawning in the corridor yields slot 7, walking down through the door into the Kitchen yields slot 5, and walking back up restores slot 7 — all read from the server's Players row.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "spawn_corridor" },
    { "op": "press_action", "action": "move_down" },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 5, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_down" },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "in_kitchen" },
    { "op": "press_action", "action": "move_up" },
    { "op": "press_action", "action": "move_left" },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 7, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_up" },
    { "op": "release_action", "action": "move_left" },
    { "op": "checkpoint", "name": "back_in_corridor" },
    { "op": "quit" }
  ]
}
