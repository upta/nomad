{
  "scenario_id": "wreck_seeds_loot_and_hazards",
  "version": 3,
  "description": "The abandoned wreck node seeds salvage and hazards. At Quiet (ship-in-space) there are no resource nodes, creatures, or loose loot. SetActiveNode(Wreck) seeds 2 WreckageDebris nodes far out on the exterior grid (x>600), scatters 3 loose World loot items (2 Scrap + 1 rarer Components), and spawns 2 crawlers as the wreck's hazard. Switching back to Quiet clears every transient: nodes, creatures, and the uncollected exterior loot.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "at_quiet" },
    { "op": "assert_value", "checkpoint": "at_quiet", "path": "harness_state.node.kind", "comparator": "eq", "expected": "Quiet" },
    { "op": "assert_value", "checkpoint": "at_quiet", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "at_quiet", "path": "harness_state.creatures.count", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "at_quiet", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0 },

    { "op": "press_action", "action": "test_set_node_wreck" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_node_wreck" },
    { "op": "wait_until", "path": "harness_state.node.kind", "comparator": "eq", "expected": "Wreck", "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 2, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 3, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.creatures.count", "comparator": "eq", "expected": 2, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "at_wreck" },
    { "op": "assert_value", "checkpoint": "at_wreck", "path": "harness_state.nodes.list.0.type", "comparator": "eq", "expected": "WreckageDebris" },
    { "op": "assert_value", "checkpoint": "at_wreck", "path": "harness_state.nodes.list.1.type", "comparator": "eq", "expected": "WreckageDebris" },
    { "op": "assert_value", "checkpoint": "at_wreck", "path": "harness_state.nodes.list.0.x", "comparator": "gt", "expected": 600 },
    { "op": "assert_value", "checkpoint": "at_wreck", "path": "harness_state.nodes.list.1.x", "comparator": "gt", "expected": 600 },
    { "op": "assert_value", "checkpoint": "at_wreck", "path": "harness_state.items.by_type.Scrap", "comparator": "eq", "expected": 2 },
    { "op": "assert_value", "checkpoint": "at_wreck", "path": "harness_state.items.by_type.Components", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "at_wreck", "path": "harness_state.items.world.0.x", "comparator": "gt", "expected": 600 },
    { "op": "assert_value", "checkpoint": "at_wreck", "path": "harness_state.creatures.count", "comparator": "eq", "expected": 2 },
    { "op": "assert_value", "checkpoint": "at_wreck", "path": "harness_state.creatures.list.0.type", "comparator": "eq", "expected": "Crawler" },

    { "op": "press_action", "action": "test_set_node_quiet" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_node_quiet" },
    { "op": "wait_until", "path": "harness_state.node.kind", "comparator": "eq", "expected": "Quiet", "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "back_at_quiet" },
    { "op": "assert_value", "checkpoint": "back_at_quiet", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "back_at_quiet", "path": "harness_state.creatures.count", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "back_at_quiet", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0 },
    { "op": "quit" }
  ]
}
