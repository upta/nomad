{
  "scenario_id": "fire_spreads_deterministically",
  "version": 3,
  "description": "The HazardTick spreads fire across floor cells. The player is teleported far away (so proximity damage never muddies the count), one fire is ignited at the Reactor room center, and as its intensity crosses the spread threshold the tick seeds adjacent floor cells one per tick, bounded by MaxHazards. The seed is Fire on room slot 0 and the count grows past one.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "press_action", "action": "test_teleport_player_far" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_teleport_player_far" },
    { "op": "press_action", "action": "test_fast_hazards_spread" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_fast_hazards_spread" },
    { "op": "press_action", "action": "test_ignite_reactor" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_ignite_reactor" },
    { "op": "wait_until", "path": "harness_state.hazards.count", "comparator": "gte", "expected": 1, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "seeded" },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.hazards.list.0.type", "comparator": "eq", "expected": "Fire" },
    { "op": "assert_value", "checkpoint": "seeded", "path": "harness_state.hazards.list.0.room_slot", "comparator": "eq", "expected": 0 },
    { "op": "wait_until", "path": "harness_state.hazards.count", "comparator": "gt", "expected": 1, "timeout_frames": 600 },
    { "op": "checkpoint", "name": "spread" },
    { "op": "assert_value", "checkpoint": "spread", "path": "harness_state.hazards.count", "comparator": "gt", "expected": 1 },
    { "op": "assert_value", "checkpoint": "spread", "path": "harness_state.hazards.count", "comparator": "lte", "expected": 6 },
    { "op": "quit" }
  ]
}
