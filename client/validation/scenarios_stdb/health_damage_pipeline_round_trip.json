{
  "scenario_id": "health_damage_pipeline_round_trip",
  "version": 3,
  "description": "The damage pipeline round-trips through the server: a connected client spawns with full health, ApplyDebugDamage drops it by the requested amount, lethal damage clamps at zero and sets IsDead, further damage no-ops while dead, and ResetVitals restores full health.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 100, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "spawned" },
    { "op": "assert_value", "checkpoint": "spawned", "path": "harness_state.vitals.max_health", "comparator": "eq", "expected": 100 },
    { "op": "assert_value", "checkpoint": "spawned", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": false },
    { "op": "press_action", "action": "test_damage_30" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_damage_30" },
    { "op": "wait_until", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 70, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "damaged" },
    { "op": "assert_value", "checkpoint": "damaged", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": false },
    { "op": "press_action", "action": "test_damage_kill" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_damage_kill" },
    { "op": "wait_until", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "dead" },
    { "op": "assert_value", "checkpoint": "dead", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 0 },
    { "op": "press_action", "action": "test_damage_30" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_damage_30" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "checkpoint", "name": "dead_no_overkill" },
    { "op": "assert_value", "checkpoint": "dead_no_overkill", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "dead_no_overkill", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "test_reset_vitals" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_reset_vitals" },
    { "op": "wait_until", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 100, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "restored" },
    { "op": "assert_value", "checkpoint": "restored", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": false },
    { "op": "quit" }
  ]
}
