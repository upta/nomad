{
  "scenario_id": "cargo_store_rejections",
  "version": 3,
  "description": "Cargo storage rejection matrix: storing into the Cargo Bay from the corridor spawn is rejected (out of reach), loading an ore into the Kitchen is rejected (room accepts neither storage nor that tank item), storing into a full cargo store is rejected, and withdrawing with a full hotbar is rejected - the item stays Stored.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_disable_fuel_burn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_disable_fuel_burn" },
    { "op": "wait_until", "path": "harness_state.power.fuel_per_burn", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_give_ore_slot0" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_give_ore_slot0" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_store_slot0_to_cargo" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_store_slot0_to_cargo" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "checkpoint", "name": "reach_rejected" },
    { "op": "assert_value", "checkpoint": "reach_rejected", "path": "harness_state.items.hotbar.0", "comparator": "eq", "expected": "RawOre" },
    { "op": "assert_value", "checkpoint": "reach_rejected", "path": "harness_state.items.stored_count", "comparator": "eq", "expected": 0 },
    { "op": "press_action", "action": "test_load_slot0_to_kitchen" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_load_slot0_to_kitchen" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "checkpoint", "name": "kitchen_rejected" },
    { "op": "assert_value", "checkpoint": "kitchen_rejected", "path": "harness_state.items.hotbar.0", "comparator": "eq", "expected": "RawOre" },
    { "op": "assert_value", "checkpoint": "kitchen_rejected", "path": "harness_state.items.stored_count", "comparator": "eq", "expected": 0 },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.connection.local_entity.x", "comparator": "gte", "expected": 340, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_right" },
    { "op": "press_action", "action": "move_down" },
    { "op": "press_action", "action": "move_left" },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 6, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_left" },
    { "op": "wait_until", "path": "harness_state.connection.local_entity.y", "comparator": "gte", "expected": 130, "timeout_frames": 300 },
    { "op": "release_action", "action": "move_down" },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_fill_cargo" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_fill_cargo" },
    { "op": "wait_until", "path": "harness_state.items.stored_count", "comparator": "eq", "expected": 12, "timeout_frames": 600 },
    { "op": "press_action", "action": "test_give_ore_slot0" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_give_ore_slot0" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_store_slot0_to_cargo" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_store_slot0_to_cargo" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "checkpoint", "name": "full_store_rejected" },
    { "op": "assert_value", "checkpoint": "full_store_rejected", "path": "harness_state.items.stored_count", "comparator": "eq", "expected": 12 },
    { "op": "assert_value", "checkpoint": "full_store_rejected", "path": "harness_state.items.hotbar.0", "comparator": "eq", "expected": "RawOre" },
    { "op": "press_action", "action": "test_fill_hotbar" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_fill_hotbar" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 4, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_withdraw_first_stored" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_withdraw_first_stored" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "checkpoint", "name": "full_hotbar_rejected" },
    { "op": "assert_value", "checkpoint": "full_hotbar_rejected", "path": "harness_state.items.stored_count", "comparator": "eq", "expected": 12 },
    { "op": "assert_value", "checkpoint": "full_hotbar_rejected", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 4 },
    { "op": "quit" }
  ]
}
