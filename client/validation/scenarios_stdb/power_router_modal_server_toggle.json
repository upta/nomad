{
  "scenario_id": "power_router_modal_server_toggle",
  "version": 3,
  "description": "In the real game against a live server: walk to the Reactor terminal, open the PowerRouter modal, and remote-toggle the Kitchen row — the ToggleBreaker reducer flips the server's breaker state and the modal stays open with live data.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "press_action", "action": "test_disable_fuel_burn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_disable_fuel_burn" },
    { "op": "wait_until", "path": "harness_state.power.fuel_per_burn", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "press_action", "action": "move_left" },
    { "op": "wait_until", "path": "harness_state.game.player.x", "comparator": "lte", "expected": -330, "timeout_frames": 300 },
    { "op": "release_action", "action": "move_left" },
    { "op": "press_action", "action": "move_up" },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.game.player.y", "comparator": "lte", "expected": -190, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.player.x", "comparator": "gte", "expected": -250, "timeout_frames": 300 },
    { "op": "release_action", "action": "move_up" },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "move_down" },
    { "op": "press_action", "action": "move_left" },
    { "op": "wait_until", "path": "harness_state.game.focused_label", "comparator": "contains", "expected": "Reactor Terminal", "timeout_frames": 300 },
    { "op": "release_action", "action": "move_down" },
    { "op": "release_action", "action": "move_left" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.game.modal.open", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "modal_open" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.game.modal.title", "comparator": "eq", "expected": "Reactor" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.power.rooms.5.breaker_on", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 3 },
    { "op": "press_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 3 },
    { "op": "press_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 3 },
    { "op": "press_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 3 },
    { "op": "press_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_down" },
    { "op": "wait_frames", "frames": 3 },
    { "op": "press_action", "action": "modal_accept" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_accept" },
    { "op": "wait_until", "path": "harness_state.power.rooms.5.breaker_on", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "server_toggled_off" },
    { "op": "assert_value", "checkpoint": "server_toggled_off", "path": "harness_state.power.rooms.5.is_powered", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "server_toggled_off", "path": "harness_state.game.modal.open", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "modal_accept" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_accept" },
    { "op": "wait_until", "path": "harness_state.power.rooms.5.breaker_on", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "server_toggled_back" },
    { "op": "press_action", "action": "ui_cancel_modal" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "ui_cancel_modal" },
    { "op": "wait_until", "path": "harness_state.game.modal.open", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "quit" }
  ]
}
