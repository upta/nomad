{
  "scenario_id": "airlock_transition",
  "version": 3,
  "description": "The full client airlock loop in the real game with a single always-present ship door. Switching to the Planetside node swaps the client to the exterior map (active_node follows). The crew walks up to the ship airlock, interacts ('Exit to surface'), and EnterExterior crosses them out — the body snaps just outside onto the surface (in_exterior true, player x>500). Walking back to the SAME door and interacting (now labelled 'Enter ship') brings them back inside (in_exterior false, player x<500).",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 7, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_set_node_planetside" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_node_planetside" },
    { "op": "wait_until", "path": "harness_state.node.kind", "comparator": "eq", "expected": "Planetside", "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.active_node", "comparator": "eq", "expected": "Planetside", "timeout_frames": 300 },
    { "op": "checkpoint", "name": "on_planetside" },
    { "op": "press_action", "action": "test_clear_creatures" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_creatures" },

    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.game.focused_label", "comparator": "contains", "expected": "Exit to surface", "timeout_frames": 900 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 6 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.zone.in_exterior", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "on_surface" },
    { "op": "assert_value", "checkpoint": "on_surface", "path": "harness_state.zone.in_exterior", "comparator": "eq", "expected": true },
    { "op": "assert_value", "checkpoint": "on_surface", "path": "harness_state.game.player.x", "comparator": "gt", "expected": 500 },
    { "op": "assert_value", "checkpoint": "on_surface", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": -1 },

    { "op": "press_action", "action": "move_left" },
    { "op": "wait_until", "path": "harness_state.game.focused_label", "comparator": "contains", "expected": "Enter ship", "timeout_frames": 600 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 6 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.zone.in_exterior", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "release_action", "action": "move_left" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "back_inside" },
    { "op": "assert_value", "checkpoint": "back_inside", "path": "harness_state.zone.in_exterior", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "back_inside", "path": "harness_state.game.player.x", "comparator": "lt", "expected": 500 },
    { "op": "quit" }
  ]
}
