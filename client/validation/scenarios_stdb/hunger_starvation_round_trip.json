{
  "scenario_id": "hunger_starvation_round_trip",
  "version": 3,
  "description": "The hunger meter end-to-end: hunger depletes on the vitals tick regardless of location, an empty stomach applies starvation damage through the damage pipeline, and RestoreHunger refills the meter and stops the bleeding (health holds — no passive regen).",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "press_action", "action": "test_fast_hunger" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_fast_hunger" },
    { "op": "press_action", "action": "test_reset_vitals" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_reset_vitals" },
    { "op": "wait_until", "path": "harness_state.vitals.hunger", "comparator": "gt", "expected": 90, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "spawned" },
    { "op": "assert_value", "checkpoint": "spawned", "path": "harness_state.vitals.max_hunger", "comparator": "eq", "expected": 100 },
    { "op": "press_action", "action": "test_set_hunger_low" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_hunger_low" },
    { "op": "wait_until", "path": "harness_state.vitals.hunger", "comparator": "eq", "expected": 0, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.vitals.health", "comparator": "lt", "expected": 100, "timeout_frames": 600 },
    { "op": "checkpoint", "name": "starving" },
    { "op": "assert_value", "checkpoint": "starving", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": false },
    { "op": "press_action", "action": "test_restore_hunger" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_restore_hunger" },
    { "op": "wait_until", "path": "harness_state.vitals.hunger", "comparator": "gt", "expected": 80, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "fed" },
    { "op": "wait_frames", "frames": 90 },
    { "op": "checkpoint", "name": "health_stable" },
    {
      "op": "assert_pipeline",
      "sources": {
        "health_at_fed": { "kind": "checkpoint", "checkpoint": "fed", "path": "harness_state.vitals.health" },
        "health_later": { "kind": "checkpoint", "checkpoint": "health_stable", "path": "harness_state.vitals.health" }
      },
      "pipeline": [
        { "op": "subtract", "inputs": ["health_later", "health_at_fed"], "as": "health_delta" }
      ],
      "assert": { "actual": "health_delta", "comparator": "eq", "expected": 0 }
    },
    { "op": "quit" }
  ]
}
