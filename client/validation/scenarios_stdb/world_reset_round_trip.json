{
  "scenario_id": "world_reset_round_trip",
  "version": 3,
  "description": "The top-right Reset World debug button wipes run state back to the Init seed. Dirty every system (spawn a world item, fill a hotbar slot, damage health, equip a suit, drain fuel, zero biomass, cut a breaker, depressurize a room, add a resource node), then press the REAL DebugHud button and assert items/vitals/stores/power/rooms/nodes are all restored to their seed values.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_spawn_ore_at_origin" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_ore_at_origin" },
    { "op": "press_action", "action": "test_give_biomass_slot0" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_give_biomass_slot0" },
    { "op": "press_action", "action": "test_damage_30" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_damage_30" },
    { "op": "press_action", "action": "test_equip_suit" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_equip_suit" },
    { "op": "press_action", "action": "test_set_fuel_two" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_fuel_two" },
    { "op": "press_action", "action": "test_set_biomass_zero" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_biomass_zero" },
    { "op": "press_action", "action": "test_toggle_breaker_2" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_toggle_breaker_2" },
    { "op": "press_action", "action": "test_depressurize_kitchen" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_depressurize_kitchen" },
    { "op": "press_action", "action": "test_spawn_ore_node" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_ore_node" },

    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 5, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.power.rooms.5.is_pressurized", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.power.rooms.2.is_powered", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.stores.biomass", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "dirtied" },
    { "op": "assert_value", "checkpoint": "dirtied", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "dirtied", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "dirtied", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 70 },
    { "op": "assert_value", "checkpoint": "dirtied", "path": "harness_state.vitals.suit_equipped", "comparator": "eq", "expected": true },
    { "op": "assert_value", "checkpoint": "dirtied", "path": "harness_state.vitals.max_oxygen", "comparator": "eq", "expected": 200 },
    { "op": "assert_value", "checkpoint": "dirtied", "path": "harness_state.stores.fuel", "comparator": "eq", "expected": 2 },
    { "op": "assert_value", "checkpoint": "dirtied", "path": "harness_state.stores.biomass", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "dirtied", "path": "harness_state.power.rooms.2.breaker_on", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "dirtied", "path": "harness_state.power.rooms.2.is_powered", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "dirtied", "path": "harness_state.power.rooms.5.is_pressurized", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "dirtied", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 5 },

    { "op": "press_action", "action": "test_press_debug_reset" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_press_debug_reset" },

    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 4, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.stores.biomass", "comparator": "eq", "expected": 3, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.power.rooms.2.is_powered", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.power.rooms.5.is_pressurized", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "reset" },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 100 },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.vitals.suit_equipped", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.vitals.max_oxygen", "comparator": "eq", "expected": 100 },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.stores.fuel", "comparator": "eq", "expected": 10 },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.stores.biomass", "comparator": "eq", "expected": 3 },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.power.status", "comparator": "eq", "expected": "Stable" },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.power.reactor_output", "comparator": "eq", "expected": 10 },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.power.rooms.0.is_powered", "comparator": "eq", "expected": true },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.power.rooms.2.breaker_on", "comparator": "eq", "expected": true },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.power.rooms.2.is_powered", "comparator": "eq", "expected": true },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.power.rooms.5.is_pressurized", "comparator": "eq", "expected": true },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.power.rooms.7.is_pressurized", "comparator": "eq", "expected": true },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 4 },
    { "op": "assert_value", "checkpoint": "reset", "path": "harness_state.nodes.list.0.yield_remaining", "comparator": "eq", "expected": 5 },
    { "op": "quit" }
  ]
}
