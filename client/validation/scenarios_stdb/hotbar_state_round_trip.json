{
  "scenario_id": "hotbar_state_round_trip",
  "version": 3,
  "description": "GiveItem lands Hotbar-located rows in distinct slots the client sees (Biomass slot 0, RawOre slot 2), InventoryConfig exposes 4 hotbar slots, giving into an occupied slot is rejected leaving state unchanged, and the connected Main HUD renders the held items.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "gte", "expected": 7, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_reset_vitals" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_reset_vitals" },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "cleared" },
    { "op": "assert_value", "checkpoint": "cleared", "path": "harness_state.items.config.hotbar_slots", "comparator": "eq", "expected": 4 },
    { "op": "press_action", "action": "test_give_biomass_slot0" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_give_biomass_slot0" },
    { "op": "press_action", "action": "test_give_ore_slot2" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_give_ore_slot2" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 2, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "given" },
    { "op": "assert_value", "checkpoint": "given", "path": "harness_state.items.hotbar.0", "comparator": "eq", "expected": "Biomass" },
    { "op": "assert_value", "checkpoint": "given", "path": "harness_state.items.hotbar.2", "comparator": "eq", "expected": "RawOre" },
    { "op": "wait_until", "path": "harness_state.game.hotbar.slots.0.glyph", "comparator": "eq", "expected": "B", "timeout_frames": 300 },
    { "op": "checkpoint", "name": "hud_renders" },
    { "op": "assert_value", "checkpoint": "hud_renders", "path": "harness_state.game.hotbar.slots.2.glyph", "comparator": "eq", "expected": "O" },
    { "op": "assert_value", "checkpoint": "hud_renders", "path": "harness_state.game.hotbar.slots.1.occupied", "comparator": "eq", "expected": false },
    { "op": "press_action", "action": "test_give_ore_slot0" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "release_action", "action": "test_give_ore_slot0" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "checkpoint", "name": "occupied_rejected" },
    { "op": "assert_value", "checkpoint": "occupied_rejected", "path": "harness_state.items.hotbar.0", "comparator": "eq", "expected": "Biomass" },
    { "op": "assert_value", "checkpoint": "occupied_rejected", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 2 },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "quit" }
  ]
}
