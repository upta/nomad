{
  "scenario_id": "item_pickup_drop_round_trip",
  "version": 3,
  "description": "Full pickup/drop loop through the real interact path: a world ore at the spawn point focuses with a 'Pick up Raw Ore' prompt, E moves it into hotbar slot 0 (row becomes Hotbar-located, world node freed, prompt cleared, HUD renders the ore), then after walking away Q drops it back into the world at the server-known player position.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "done_contract": { "drop_position_tolerance": 2.0 },
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "gte", "expected": 7, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_reset_vitals" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_reset_vitals" },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_spawn_ore_at_origin" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_ore_at_origin" },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.world_item_nodes", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.focused_label", "comparator": "eq", "expected": "Pick up Raw Ore", "timeout_frames": 300 },
    { "op": "checkpoint", "name": "focused" },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.world_item_nodes", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.focused_label", "comparator": "eq", "expected": "", "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.hotbar.slots.0.glyph", "comparator": "eq", "expected": "O", "timeout_frames": 300 },
    { "op": "checkpoint", "name": "picked_up" },
    { "op": "assert_value", "checkpoint": "picked_up", "path": "harness_state.items.hotbar.0", "comparator": "eq", "expected": "RawOre" },
    { "op": "assert_value", "checkpoint": "picked_up", "path": "harness_state.game.hotbar.slots.0.occupied", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.game.player.displacement_from_start", "comparator": "gt", "expected": 40, "timeout_frames": 300 },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "press_action", "action": "hotbar_drop" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "hotbar_drop" },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.world_item_nodes", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "dropped" },
    { "op": "assert_value", "checkpoint": "dropped", "path": "harness_state.game.hotbar.slots.0.occupied", "comparator": "eq", "expected": false },
    {
      "op": "assert_pipeline",
      "sources": {
        "item_x": { "kind": "checkpoint", "checkpoint": "dropped", "path": "harness_state.items.world.0.x" },
        "entity_x": { "kind": "checkpoint", "checkpoint": "dropped", "path": "harness_state.connection.local_entity.x" },
        "tolerance": { "kind": "contract", "path": "done_contract.drop_position_tolerance" }
      },
      "pipeline": [
        { "op": "subtract", "inputs": ["item_x", "entity_x"], "as": "diff" },
        { "op": "abs", "inputs": ["diff"], "as": "abs_diff" }
      ],
      "assert": { "actual": "abs_diff", "comparator": "lte", "expected_source": "tolerance" }
    },
    {
      "op": "assert_pipeline",
      "sources": {
        "item_y": { "kind": "checkpoint", "checkpoint": "dropped", "path": "harness_state.items.world.0.y" },
        "entity_y": { "kind": "checkpoint", "checkpoint": "dropped", "path": "harness_state.connection.local_entity.y" },
        "tolerance": { "kind": "contract", "path": "done_contract.drop_position_tolerance" }
      },
      "pipeline": [
        { "op": "subtract", "inputs": ["item_y", "entity_y"], "as": "diff" },
        { "op": "abs", "inputs": ["diff"], "as": "abs_diff" }
      ],
      "assert": { "actual": "abs_diff", "comparator": "lte", "expected_source": "tolerance" }
    },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "quit" }
  ]
}
