{
  "scenario_id": "harvest_full_hotbar_drops_world",
  "version": 3,
  "description": "When the hotbar fills mid-channel, completion drops the yield as a World item at the node instead of wasting the channel: start a harvest with an empty hotbar, fill all four slots during the channel, and on completion the hotbar stays full (no RawOre), the world item count rises, and the node yield still decrements.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "done_contract": { "min_world_gain": 1 },
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "gte", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 4, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_clear_nodes" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_nodes" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "before" },
    { "op": "assert_value", "checkpoint": "before", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0 },

    { "op": "press_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_until", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": true, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_fill_hotbar" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_fill_hotbar" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 4, "timeout_frames": 300 },

    { "op": "wait_until", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 15 },
    { "op": "checkpoint", "name": "after" },

    { "op": "assert_value", "checkpoint": "after", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 4 },
    { "op": "assert_value", "checkpoint": "after", "path": "harness_state.items.hotbar.0", "comparator": "eq", "expected": "Scrap" },
    { "op": "assert_value", "checkpoint": "after", "path": "harness_state.items.hotbar.3", "comparator": "eq", "expected": "Scrap" },
    { "op": "assert_value", "checkpoint": "after", "path": "harness_state.nodes.list.0.yield_remaining", "comparator": "eq", "expected": 4 },
    {
      "op": "assert_pipeline",
      "sources": {
        "before_world": { "kind": "checkpoint", "checkpoint": "before", "path": "harness_state.items.world_count" },
        "after_world": { "kind": "checkpoint", "checkpoint": "after", "path": "harness_state.items.world_count" },
        "min_gain": { "kind": "contract", "path": "done_contract.min_world_gain" }
      },
      "pipeline": [
        { "op": "subtract", "inputs": ["after_world", "before_world"], "as": "world_gain" }
      ],
      "assert": { "actual": "world_gain", "comparator": "gte", "expected_source": "min_gain" }
    },

    { "op": "quit" }
  ]
}
