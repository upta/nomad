{
  "scenario_id": "oxygen_depletes_and_refills",
  "version": 3,
  "description": "The oxygen tether end-to-end: walking into the pressurized powered Kitchen holds the tank full; depressurizing the Kitchen makes the VitalsTick drain it; repressurizing refills it back to max. Health stays untouched while oxygen never empties.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.vitals.oxygen", "comparator": "eq", "expected": 100, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "move_down" },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 5, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_down" },
    { "op": "release_action", "action": "move_right" },
    { "op": "press_action", "action": "test_fast_vitals" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_fast_vitals" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "in_kitchen_full_tank" },
    { "op": "assert_value", "checkpoint": "in_kitchen_full_tank", "path": "harness_state.vitals.oxygen", "comparator": "eq", "expected": 100 },
    { "op": "assert_value", "checkpoint": "in_kitchen_full_tank", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 100 },
    { "op": "press_action", "action": "test_depressurize_kitchen" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_depressurize_kitchen" },
    { "op": "wait_until", "path": "harness_state.vitals.oxygen", "comparator": "lt", "expected": 60, "timeout_frames": 600 },
    { "op": "checkpoint", "name": "depleting" },
    { "op": "assert_value", "checkpoint": "depleting", "path": "harness_state.vitals.oxygen", "comparator": "gt", "expected": 0 },
    { "op": "assert_value", "checkpoint": "depleting", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 100 },
    { "op": "press_action", "action": "test_repressurize_kitchen" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_repressurize_kitchen" },
    { "op": "wait_until", "path": "harness_state.vitals.oxygen", "comparator": "eq", "expected": 100, "timeout_frames": 600 },
    { "op": "checkpoint", "name": "refilled" },
    { "op": "assert_value", "checkpoint": "refilled", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 100 },
    { "op": "quit" }
  ]
}
