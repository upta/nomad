{
  "scenario_id": "load_biomass_modal_round_trip",
  "version": 3,
  "description": "Depositing biomass through the real CloningModal: carry a biomass item to the Cloning Bay terminal, open the modal (no dead crew, so the Deposit row holds focus), accept - the ship's biomass store gains one, the hotbar slot empties, and the modal stays open showing the updated count.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_reset_vitals" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_reset_vitals" },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_set_biomass_full" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_biomass_full" },
    { "op": "wait_until", "path": "harness_state.stores.biomass", "comparator": "eq", "expected": 3, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_give_biomass_slot0" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_give_biomass_slot0" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.game.player.x", "comparator": "gt", "expected": 60, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_right" },
    { "op": "press_action", "action": "move_up" },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 2, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.game.focused_label", "comparator": "contains", "expected": "Cloning Bay Terminal", "timeout_frames": 600 },
    { "op": "release_action", "action": "move_up" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.game.modal.open", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "modal_open" },
    { "op": "assert_value", "checkpoint": "modal_open", "path": "harness_state.game.modal.title", "comparator": "contains", "expected": "Cloning" },
    { "op": "press_action", "action": "modal_accept" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "modal_accept" },
    { "op": "wait_until", "path": "harness_state.stores.biomass", "comparator": "eq", "expected": 4, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "deposited" },
    { "op": "assert_value", "checkpoint": "deposited", "path": "harness_state.game.modal.open", "comparator": "eq", "expected": true },
    { "op": "assert_value", "checkpoint": "deposited", "path": "harness_state.stores.biomass", "comparator": "eq", "expected": 4 },
    { "op": "press_action", "action": "ui_cancel_modal" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "ui_cancel_modal" },
    { "op": "wait_until", "path": "harness_state.game.modal.open", "comparator": "eq", "expected": false, "timeout_frames": 120 },
    { "op": "quit" }
  ]
}
