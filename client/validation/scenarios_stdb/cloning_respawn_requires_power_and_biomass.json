{
  "scenario_id": "cloning_respawn_requires_power_and_biomass",
  "version": 3,
  "description": "Respawn gating: a dead player stays ghosted while the Cloning Bay is unpowered, stays ghosted with zero biomass, and only respawns once both power and biomass are available (GDD §6.4).",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "press_action", "action": "test_disable_fuel_burn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_disable_fuel_burn" },
    { "op": "wait_until", "path": "harness_state.power.fuel_per_burn", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "press_action", "action": "test_reset_vitals" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_reset_vitals" },
    { "op": "press_action", "action": "test_set_biomass_full" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_biomass_full" },
    { "op": "wait_until", "path": "harness_state.stores.biomass", "comparator": "eq", "expected": 3, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_damage_kill" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_damage_kill" },
    { "op": "wait_until", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_toggle_breaker_2" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_toggle_breaker_2" },
    { "op": "wait_until", "path": "harness_state.power.rooms.2.is_powered", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_request_respawn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_request_respawn" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "checkpoint", "name": "rejected_unpowered" },
    { "op": "assert_value", "checkpoint": "rejected_unpowered", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": true },
    { "op": "assert_value", "checkpoint": "rejected_unpowered", "path": "harness_state.stores.biomass", "comparator": "eq", "expected": 3 },
    { "op": "press_action", "action": "test_toggle_breaker_2" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_toggle_breaker_2" },
    { "op": "wait_until", "path": "harness_state.power.rooms.2.is_powered", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_set_biomass_zero" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_biomass_zero" },
    { "op": "wait_until", "path": "harness_state.stores.biomass", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_request_respawn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_request_respawn" },
    { "op": "wait_frames", "frames": 30 },
    { "op": "checkpoint", "name": "rejected_no_biomass" },
    { "op": "assert_value", "checkpoint": "rejected_no_biomass", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": true },
    { "op": "press_action", "action": "test_set_biomass_full" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_biomass_full" },
    { "op": "wait_until", "path": "harness_state.stores.biomass", "comparator": "eq", "expected": 3, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_request_respawn" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_request_respawn" },
    { "op": "wait_until", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "respawned" },
    { "op": "assert_value", "checkpoint": "respawned", "path": "harness_state.stores.biomass", "comparator": "eq", "expected": 2 },
    { "op": "quit" }
  ]
}
