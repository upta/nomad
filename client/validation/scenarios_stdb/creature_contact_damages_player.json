{
  "scenario_id": "creature_contact_damages_player",
  "version": 3,
  "description": "A surface creature damages a player on contact via DamageType.Creature, and fleeing out of range stops it. The player crosses the airlock onto the Planetside surface; a fast creature is spawned on their own cell (spawn-at-player pattern) so the CreatureTick contacts immediately and health falls. Teleporting the player far out of chase range leaves the creature patrolling and health holds steady.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_until", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 100, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_set_node_planetside" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_set_node_planetside" },
    { "op": "wait_until", "path": "harness_state.node.kind", "comparator": "eq", "expected": "Planetside", "timeout_frames": 300 },
    { "op": "press_action", "action": "test_clear_creatures" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_creatures" },
    { "op": "wait_until", "path": "harness_state.creatures.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_fast_creatures" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_fast_creatures" },

    { "op": "press_action", "action": "test_teleport_to_airlock" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_teleport_to_airlock" },
    { "op": "press_action", "action": "test_enter_exterior" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_enter_exterior" },
    { "op": "wait_until", "path": "harness_state.zone.in_exterior", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "before" },
    { "op": "assert_value", "checkpoint": "before", "path": "harness_state.vitals.health", "comparator": "eq", "expected": 100 },

    { "op": "press_action", "action": "test_spawn_creature_at_player" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_creature_at_player" },
    { "op": "wait_until", "path": "harness_state.creatures.count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "spawned" },
    { "op": "assert_value", "checkpoint": "spawned", "path": "harness_state.creatures.list.0.type", "comparator": "eq", "expected": "Crawler" },

    { "op": "wait_until", "path": "harness_state.vitals.health", "comparator": "lt", "expected": 95, "timeout_frames": 600 },
    { "op": "checkpoint", "name": "contacted" },
    { "op": "assert_value", "checkpoint": "contacted", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": false },
    {
      "op": "assert_pipeline",
      "sources": {
        "h0": { "kind": "checkpoint", "checkpoint": "before", "path": "harness_state.vitals.health" },
        "h1": { "kind": "checkpoint", "checkpoint": "contacted", "path": "harness_state.vitals.health" }
      },
      "pipeline": [{ "op": "subtract", "inputs": ["h1", "h0"], "as": "delta" }],
      "assert": { "actual": "delta", "comparator": "lt", "expected": 0 }
    },

    { "op": "press_action", "action": "test_teleport_player_far" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_teleport_player_far" },
    { "op": "wait_frames", "frames": 20 },
    { "op": "checkpoint", "name": "fled_start" },
    { "op": "wait_frames", "frames": 90 },
    { "op": "checkpoint", "name": "fled_end" },
    { "op": "assert_value", "checkpoint": "fled_end", "path": "harness_state.vitals.is_dead", "comparator": "eq", "expected": false },
    {
      "op": "assert_pipeline",
      "sources": {
        "f0": { "kind": "checkpoint", "checkpoint": "fled_start", "path": "harness_state.vitals.health" },
        "f1": { "kind": "checkpoint", "checkpoint": "fled_end", "path": "harness_state.vitals.health" }
      },
      "pipeline": [
        { "op": "subtract", "inputs": ["f1", "f0"], "as": "hold" },
        { "op": "abs", "inputs": ["hold"], "as": "abs_hold" }
      ],
      "assert": { "actual": "abs_hold", "comparator": "lte", "expected": 0.5 }
    },
    { "op": "quit" }
  ]
}
