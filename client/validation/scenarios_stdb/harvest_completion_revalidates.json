{
  "scenario_id": "harvest_completion_revalidates",
  "version": 3,
  "description": "ChannelTick re-validates at completion regardless of the client (bounded client-trust). Two paths on a live, un-cancelled channel: (A) the node is depleted mid-channel -> completion yields nothing and the row still clears; (B) the player's server entity is moved out of reach mid-channel without a CancelHarvest -> completion's reach re-check yields nothing and the node is untouched.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "gte", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 4, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_clear_nodes" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_nodes" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_until", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.harvest.progress", "comparator": "gt", "expected": 0.1, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_deplete_nearest_node" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_deplete_nearest_node" },
    { "op": "wait_until", "path": "harness_state.nodes.list.0.yield_remaining", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 15 },
    { "op": "checkpoint", "name": "depleted_mid_channel" },
    { "op": "assert_value", "checkpoint": "depleted_mid_channel", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "depleted_mid_channel", "path": "harness_state.nodes.list.0.yield_remaining", "comparator": "eq", "expected": 0 },

    { "op": "press_action", "action": "test_clear_nodes" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_nodes" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_until", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.harvest.progress", "comparator": "gt", "expected": 0.1, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_teleport_player_far" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_teleport_player_far" },
    { "op": "wait_until", "path": "harness_state.connection.local_entity.displacement_from_initial", "comparator": "gt", "expected": 1000, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 15 },
    { "op": "checkpoint", "name": "out_of_reach_at_completion" },
    { "op": "assert_value", "checkpoint": "out_of_reach_at_completion", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0 },
    { "op": "assert_value", "checkpoint": "out_of_reach_at_completion", "path": "harness_state.nodes.list.0.yield_remaining", "comparator": "eq", "expected": 5 },

    { "op": "quit" }
  ]
}
