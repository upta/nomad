{
  "scenario_id": "world_items_spawn_and_render",
  "version": 3,
  "description": "SpawnWorldItem inserts World-located Item rows the client sees (RawOre at origin, FuelCell in the Kitchen), the connected Main renders one WorldItem node per row, and ClearItems empties everything.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "gte", "expected": 7, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "cleared" },
    { "op": "press_action", "action": "test_spawn_ore_at_origin" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_ore_at_origin" },
    { "op": "press_action", "action": "test_spawn_fuelcell_in_kitchen" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_fuelcell_in_kitchen" },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 2, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "spawned" },
    { "op": "assert_value", "checkpoint": "spawned", "path": "harness_state.items.by_type.RawOre", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "spawned", "path": "harness_state.items.by_type.FuelCell", "comparator": "eq", "expected": 1 },
    { "op": "wait_until", "path": "harness_state.game.world_item_nodes", "comparator": "eq", "expected": 2, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "rendered" },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.game.world_item_nodes", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "cleared_again" },
    { "op": "quit" }
  ]
}
