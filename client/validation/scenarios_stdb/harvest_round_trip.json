{
  "scenario_id": "harvest_round_trip",
  "version": 3,
  "description": "A channeled harvest end-to-end against a real server: spawn a node at the player, StartHarvest pins the channel, the shared ChannelTick climbs Progress past 0.5, and on completion one unit lands in the hotbar while the node yield decrements.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "gte", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_clear_nodes" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_nodes" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },

    { "op": "press_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_spawn_node_at_player" },
    { "op": "wait_until", "path": "harness_state.nodes.count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "before" },
    { "op": "assert_value", "checkpoint": "before", "path": "harness_state.nodes.list.0.yield_remaining", "comparator": "eq", "expected": 5 },
    { "op": "assert_value", "checkpoint": "before", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0 },

    { "op": "press_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_until", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.harvest.progress", "comparator": "gt", "expected": 0.5, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "channeling" },
    { "op": "assert_value", "checkpoint": "channeling", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": true },

    { "op": "press_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_start_harvest_nearest" },
    { "op": "wait_until", "path": "harness_state.harvest.progress", "comparator": "lt", "expected": 0.3, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "restarted" },
    { "op": "assert_value", "checkpoint": "restarted", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": true },

    { "op": "wait_until", "path": "harness_state.harvest.active_exists", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "harvested" },
    { "op": "assert_value", "checkpoint": "harvested", "path": "harness_state.items.hotbar.0", "comparator": "eq", "expected": "RawOre" },
    { "op": "assert_value", "checkpoint": "harvested", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "harvested", "path": "harness_state.nodes.list.0.yield_remaining", "comparator": "eq", "expected": 4 },

    { "op": "quit" }
  ]
}
