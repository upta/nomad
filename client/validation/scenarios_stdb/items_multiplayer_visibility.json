{
  "scenario_id": "items_multiplayer_visibility",
  "version": 3,
  "description": "Checkpoint: Inventory second-client proof. The main client drops an item and the puppet client's own table view sees the world item appear; the main client then stores an item in the Cargo Bay and the puppet sees it become Stored.",
  "harness_scene": "res://validation/harnesses/MultiplayerGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/MultiplayerGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.puppet.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.puppet.world_item_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_give_ore_slot0" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_give_ore_slot0" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_drop_slot0" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_drop_slot0" },
    { "op": "wait_until", "path": "harness_state.items.world_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.puppet.world_item_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "puppet_sees_drop" },
    { "op": "assert_value", "checkpoint": "puppet_sees_drop", "path": "harness_state.puppet.world_item_count", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "puppet_sees_drop", "path": "harness_state.puppet.stored_item_count", "comparator": "eq", "expected": 0 },
    { "op": "press_action", "action": "test_clear_items" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_clear_items" },
    { "op": "wait_until", "path": "harness_state.puppet.world_item_count", "comparator": "eq", "expected": 0, "timeout_frames": 300 },
    { "op": "press_action", "action": "test_give_ore_slot0" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_give_ore_slot0" },
    { "op": "wait_until", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.connection.local_entity.x", "comparator": "gte", "expected": 340, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_right" },
    { "op": "press_action", "action": "move_down" },
    { "op": "press_action", "action": "move_left" },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 6, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_left" },
    { "op": "wait_until", "path": "harness_state.connection.local_entity.y", "comparator": "gte", "expected": 130, "timeout_frames": 300 },
    { "op": "release_action", "action": "move_down" },
    { "op": "press_action", "action": "test_store_slot0_to_cargo" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "release_action", "action": "test_store_slot0_to_cargo" },
    { "op": "wait_until", "path": "harness_state.items.stored_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.puppet.stored_item_count", "comparator": "eq", "expected": 1, "timeout_frames": 300 },
    { "op": "checkpoint", "name": "puppet_sees_store" },
    { "op": "assert_value", "checkpoint": "puppet_sees_store", "path": "harness_state.puppet.stored_item_count", "comparator": "eq", "expected": 1 },
    { "op": "assert_value", "checkpoint": "puppet_sees_store", "path": "harness_state.items.hotbar_count", "comparator": "eq", "expected": 0 },
    { "op": "quit" }
  ]
}
