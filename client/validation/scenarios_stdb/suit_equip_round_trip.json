{
  "scenario_id": "suit_equip_round_trip",
  "version": 3,
  "description": "Spacesuit equip end-to-end against the live server: walk to the Cargo Bay suit rack in the real Main, interact — SetSuitEquipped flips the server row and doubles Oxygen.Max; interacting again unequips, restores base max, and clamps the tank.",
  "harness_scene": "res://validation/harnesses/ConnectedGameHarness.tscn",
  "steps": [
    { "op": "load_harness", "scene": "res://validation/harnesses/ConnectedGameHarness.tscn" },
    { "op": "wait_until", "path": "harness_state.connection.data_ready", "comparator": "eq", "expected": true, "timeout_frames": 600 },
    { "op": "wait_until", "path": "harness_state.game.player_exists", "comparator": "eq", "expected": true, "timeout_frames": 120 },
    { "op": "wait_until", "path": "harness_state.game.terminal_count", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_until", "path": "harness_state.vitals.current_slot", "comparator": "eq", "expected": 7, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 10 },
    { "op": "checkpoint", "name": "spawned" },
    { "op": "assert_value", "checkpoint": "spawned", "path": "harness_state.vitals.suit_equipped", "comparator": "eq", "expected": false },
    { "op": "assert_value", "checkpoint": "spawned", "path": "harness_state.vitals.max_oxygen", "comparator": "eq", "expected": 100 },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.game.player.x", "comparator": "gt", "expected": 296, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "move_down" },
    { "op": "wait_until", "path": "harness_state.game.player.y", "comparator": "gt", "expected": 80, "timeout_frames": 600 },
    { "op": "release_action", "action": "move_down" },
    { "op": "press_action", "action": "move_right" },
    { "op": "wait_until", "path": "harness_state.game.player.x", "comparator": "gt", "expected": 420, "timeout_frames": 600 },
    { "op": "press_action", "action": "move_up" },
    { "op": "wait_until", "path": "harness_state.game.focused_label", "comparator": "contains", "expected": "Suit Rack", "timeout_frames": 600 },
    { "op": "release_action", "action": "move_up" },
    { "op": "release_action", "action": "move_right" },
    { "op": "wait_frames", "frames": 10 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.vitals.suit_equipped", "comparator": "eq", "expected": true, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "suited" },
    { "op": "assert_value", "checkpoint": "suited", "path": "harness_state.vitals.max_oxygen", "comparator": "eq", "expected": 200 },
    { "op": "press_action", "action": "interact" },
    { "op": "wait_frames", "frames": 5 },
    { "op": "release_action", "action": "interact" },
    { "op": "wait_until", "path": "harness_state.vitals.suit_equipped", "comparator": "eq", "expected": false, "timeout_frames": 300 },
    { "op": "wait_frames", "frames": 5 },
    { "op": "checkpoint", "name": "unequipped" },
    { "op": "assert_value", "checkpoint": "unequipped", "path": "harness_state.vitals.max_oxygen", "comparator": "eq", "expected": 100 },
    { "op": "quit" }
  ]
}
